# Database
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=rag_jobs
DB_SSL=false

# AI
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
OPENAI_API_KEY=
OPENAI_EMBED_MODEL=text-embedding-3-small

# ChromaDB (optional RAG vectors)
CHROMA_DIR=.chroma
CHROMA_COLLECTION=jobs_collection

# Event-driven stack (docker compose -f docker-compose.events.yml up -d)
EVENTS_ENABLED=false
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
REDIS_URL=redis://localhost:6379/0
ANALYTICS_DATA_PATH=./data/lake
SPARK_REPORT_PATH=./data/reports/latest.json
SPARK_MASTER=local[*]
USE_SPARK=true

# Azure production (see .env.azure.example and docs/azure/DEPLOYMENT.md)
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=empowerwork
AZURE_SPARK_REPORT_BLOB=reports/latest.json
CORS_ORIGINS=*
IDS_ENABLED=true
